{
  "id": "binaryrunner",
  "title": "Binary Runner",
  "description": "You are a Data Packet racing through a CPU. Switch lanes to solve logic gate challenges: AND, OR, XOR, NAND, NOR. How far can you run?",
  "plugin": "binaryrunner",
  "version": "1.0.0",
  "ui": {
    "emoji": "🚀",
    "showTimer": true,
    "showProgress": true,
    "showStreak": true,
    "accentColor": "#00D4FF"
  },
  "scoring": {
    "basePoints": 100,
    "timeBonus": false,
    "timeBonusPerSecond": 0,
    "streakMultiplier": false,
    "streakThreshold": 3,
    "streakMultiplierValue": 1.5
  },
  "questions": [
    {
      "id": "br-stage-1",
      "type": "binaryrunner",
      "difficulty": "easy",
      "points": 600,
      "instruction": "Stage 1 — AND & OR gates only. Switch lanes to answer!",
      "duration": 40,
      "initialSpeed": 55,
      "maxSpeed": 110,
      "speedRampPerSec": 1.2,
      "spawnInterval": 3.2,
      "operations": ["AND", "OR"]
    },
    {
      "id": "br-stage-2",
      "type": "binaryrunner",
      "difficulty": "easy",
      "points": 800,
      "instruction": "Stage 2 — XOR joins the track!",
      "duration": 40,
      "initialSpeed": 65,
      "maxSpeed": 130,
      "speedRampPerSec": 1.5,
      "spawnInterval": 2.8,
      "operations": ["AND", "OR", "XOR"]
    },
    {
      "id": "br-stage-3",
      "type": "binaryrunner",
      "difficulty": "medium",
      "points": 1100,
      "instruction": "Stage 3 — Medium speed, all basic gates!",
      "duration": 45,
      "initialSpeed": 75,
      "maxSpeed": 150,
      "speedRampPerSec": 1.8,
      "spawnInterval": 2.5,
      "operations": ["AND", "OR", "XOR"]
    },
    {
      "id": "br-stage-4",
      "type": "binaryrunner",
      "difficulty": "medium",
      "points": 1400,
      "instruction": "Stage 4 — NAND gates are live. Think twice!",
      "duration": 45,
      "initialSpeed": 85,
      "maxSpeed": 165,
      "speedRampPerSec": 2.0,
      "spawnInterval": 2.3,
      "operations": ["AND", "OR", "XOR", "NAND"]
    },
    {
      "id": "br-stage-5",
      "type": "binaryrunner",
      "difficulty": "hard",
      "points": 1800,
      "instruction": "Stage 5 — All five gates. Maximum speed approaching!",
      "duration": 50,
      "initialSpeed": 95,
      "maxSpeed": 185,
      "speedRampPerSec": 2.4,
      "spawnInterval": 2.0,
      "operations": ["AND", "OR", "XOR", "NAND", "NOR"]
    },
    {
      "id": "br-stage-6",
      "type": "binaryrunner",
      "difficulty": "hard",
      "points": 2200,
      "instruction": "ELITE — All gates, blazing speed. Survive 50 seconds!",
      "duration": 50,
      "initialSpeed": 110,
      "maxSpeed": 210,
      "speedRampPerSec": 3.0,
      "spawnInterval": 1.7,
      "operations": ["AND", "OR", "XOR", "NAND", "NOR"]
    }
  ],
  "levels": [
    {
      "id": "br-level-1",
      "title": "Boot Sequence",
      "description": "Basic AND & OR gates — warm up your logic",
      "questionIds": ["br-stage-1", "br-stage-2"],
      "passingScore": 700
    },
    {
      "id": "br-level-2",
      "title": "Logic Core",
      "description": "XOR and medium speed — keep your focus",
      "questionIds": ["br-stage-3", "br-stage-4"],
      "passingScore": 1400,
      "unlockCondition": { "previousLevelId": "br-level-1", "minScore": 700 }
    },
    {
      "id": "br-level-3",
      "title": "Kernel Panic",
      "description": "All five gates at maximum velocity — elite only",
      "questionIds": ["br-stage-5", "br-stage-6"],
      "passingScore": 2200,
      "unlockCondition": { "previousLevelId": "br-level-2", "minScore": 1400 }
    }
  ],
  "adaptiveRules": [
    {
      "condition": { "metric": "accuracy", "operator": ">=", "value": 0.9 },
      "action": { "type": "adjustDifficulty", "payload": { "difficulty": "hard" } }
    },
    {
      "condition": { "metric": "accuracy", "operator": "<", "value": 0.4 },
      "action": { "type": "adjustDifficulty", "payload": { "difficulty": "easy" } }
    }
  ]
}

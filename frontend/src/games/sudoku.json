      "passingScore": 40
    },
    {
      "id": "sdk-l2",
      "title": "Medium Sudoku",
      "description": "Fewer clues — more thinking required.",
      "questionIds": ["sdk-medium-1", "sdk-medium-2"],
      "passingScore": 40,
      "unlockCondition": { "previousLevelId": "sdk-l1", "minScore": 30 }
    },
    {
      "id": "sdk-l3",
      "title": "Hard Sudoku",
      "description": "Only for the sharpest logical minds.",
      "questionIds": ["sdk-hard-1"],
      "passingScore": 50,
      "unlockCondition": { "previousLevelId": "sdk-l2", "minScore": 40 }
    }
  ],

  "adaptiveRules": [
    {
      "condition": { "metric": "accuracy", "operator": ">=", "value": 1.0 },
      "action": { "type": "adjustDifficulty", "payload": { "difficulty": "hard" } }
    },
    {
      "condition": { "metric": "accuracy", "operator": "<", "value": 0.5 },
      "action": { "type": "showHint" }
    }
  ],

  "scoring": {
    "basePoints": 300,
    "timeBonus": true,
    "timeBonusPerSecond": 1,
    "streakMultiplier": false,
    "streakThreshold": 3,
    "streakMultiplierValue": 1.0
  },

  "ui": {
    "showTimer": true,
    "showProgress": true,
    "showStreak": false,
    "emoji": "🔢"
  }
